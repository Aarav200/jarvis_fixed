{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Jarvis (headless)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/jarvis/main.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/jarvis",
            "env": {
                "OPENAI_API_KEY": ""
            },
            "justMyCode": true
        },
        {
            "name": "Run Jarvis GUI",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/jarvis/gui.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/jarvis",
            "env": {
                "OPENAI_API_KEY": ""
            },
            "justMyCode": true
        }
    ]
}
